# API base URL for Spring Boot backend (no trailing slash).
NEXT_PUBLIC_API_URL=http://localhost:8080

# Sentry (optional but recommended). DSN can be shared between browser and server SDKs.
# Use a stable release value (for example, Git SHA) in CI/CD deployments.
# ENABLE_SENTRY_TEST_PAGE=true
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# NEXT_PUBLIC_SENTRY_RELEASE=church-registry-frontend@local
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=church-registry-frontend@local
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
# SENTRY_TRACES_SAMPLE_RATE=0

# Optional emergency rollback: re-enable Next.js internal /api/* routes in production.
# Keep unset/false for UI-only architecture.
# NEXT_ALLOW_INTERNAL_API_ROUTES=false

# Resend (optional). When set, "Email Baptism Certificate" can send PDF certificates by email.
# Get API key from https://resend.com. From address can be your verified domain or onboarding@resend.dev.
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL=Sacrament Registry <onboarding@resend.dev>
